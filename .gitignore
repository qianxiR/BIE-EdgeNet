# ============================================================
# BIE-EdgeNet .gitignore
# ============================================================

# -------------------- Python --------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
.installed.cfg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# -------------------- Virtual envs --------------------
venv/
env/
.venv/
.env
ENV/

# -------------------- Jupyter / IPython --------------------
.ipynb_checkpoints/
profile_default/
ipython_config.py
*.ipynb_checkpoints

# -------------------- pytest / coverage --------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# -------------------- IDE / Editor --------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -------------------- OS --------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# -------------------- PyTorch / 模型产物 --------------------
checkpoints/
vis/
samples_LEVIR/predict_*/
samples_LEVIR/**/predict_*/
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.engine
*.bin
# 例外:预训练主干(若需入库可解开下行注释)
#!models/pretrained/*.pth

# -------------------- 训练日志 / 崩溃回放 --------------------
replay_pid*.log
*.log
wandb/
runs/
swanlog/
mlruns/
events.out.tfevents.*

# -------------------- 大型数据索引 / 中间产物 --------------------
indice0.txt
indice1.txt
indice*.txt
*.npy
*.npz
*.pkl
# 例外:必要的归一化统计等小文件可显式 add

# -------------------- 数据集本体(请在数据集根目录另外建 .gitignore) --------------------
datasets_raw/
data/
*.tif
*.tiff
# 例外:仓库自带的小尺寸样例图可显式 add -f
!samples_LEVIR/A/*.png
!samples_LEVIR/B/*.png
!samples_LEVIR/label/*.png

# -------------------- GDAL / GeoTIFF 临时 --------------------
*.aux.xml
*.ovr
*.pyc.gdal.lock

# -------------------- 临时图片 / 截图 --------------------
微信图片_*.png
tmp_*.png
*.tmp

# -------------------- CLAUDE.md 工作产物(可选,默认入库) --------------------
# 如不希望 CLAUDE.md 进入仓库,解开下一行
# CLAUDE.md
